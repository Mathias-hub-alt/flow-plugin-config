cells:
  immersion_value:
    displayName: "Immersion Cooling"
    value:
      field: value
      interpolate: linear
      lastNotNull: true
    label:
      units: " W"
      decimalPoints: 0
    thresholds:
      steps:
        - value: 0
          color: "green"
        - value: 900
          color: "yellow"
        - value: 950
          color: "red"
